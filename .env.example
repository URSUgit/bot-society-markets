# Bot Society Markets example environment
BSM_ENVIRONMENT_NAME=development
BSM_DEPLOYMENT_TARGET=local
BSM_DATABASE_URL=
BSM_DATABASE_PATH=api/data/bot_society_markets.db
BSM_MARKET_PROVIDER=coingecko
BSM_COINGECKO_PLAN=demo
BSM_COINGECKO_API_KEY=
BSM_SIGNAL_PROVIDER=rss
BSM_TRACKED_COIN_IDS=bitcoin,ethereum,solana
BSM_RSS_FEED_URLS=https://your-feed-1.example/rss,https://your-feed-2.example/rss
BSM_REDDIT_CLIENT_ID=
BSM_REDDIT_CLIENT_SECRET=
BSM_REDDIT_USER_AGENT=BotSocietyMarkets/0.7
BSM_REDDIT_SUBREDDITS=CryptoCurrency,Bitcoin,ethtrader,solana
BSM_REDDIT_POST_LIMIT=15
BSM_WORKER_INTERVAL_SECONDS=900
BSM_WORKER_MAX_CYCLES=0
BSM_ALERT_INBOX_LIMIT=10
BSM_SESSION_TTL_HOURS=168
BSM_AUTH_COOKIE_NAME=bsm_session
BSM_OUTBOUND_TIMEOUT_SECONDS=10
BSM_NOTIFICATION_RETRY_LIMIT=25
BSM_NOTIFICATION_MAX_ATTEMPTS=4
BSM_NOTIFICATION_RETRY_BASE_SECONDS=300
BSM_SMTP_HOST=
BSM_SMTP_PORT=587
BSM_SMTP_USERNAME=
BSM_SMTP_PASSWORD=
BSM_SMTP_FROM_EMAIL=
BSM_SMTP_USE_TLS=true
